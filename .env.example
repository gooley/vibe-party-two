# Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter API Key (get from https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Directory containing your photos
PHOTO_DIRECTORY=/path/to/your/photos

# Example photo directory (uncomment and adjust as needed)
# PHOTO_DIRECTORY=/Users/yourname/Pictures/PhotoTournament
# PHOTO_DIRECTORY=/home/yourname/photos
# PHOTO_DIRECTORY=C:\Users\YourName\Pictures\Photos